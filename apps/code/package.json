    "chokidar": "^5.0.0",
    "detect-libc": "^1.0.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.0",
    "fflate": "^0.8.2",
    "file-icon": "^6.0.0",
    "fzf": "^0.5.2",
    "ignore": "^7.0.5",
    "inversify": "^7.10.6",
