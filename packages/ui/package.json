{
  "name": "@posthog/ui",
  "version": "1.0.0",
  "description": "React UI layer. Components, stores, hooks. Pure rendering and UI state — no I/O, no business logic. Built on @posthog/quill. Consumed by every host app (desktop, web, mobile-web).",
  "private": true,
  "type": "module",
  "exports": {
    "./*": [
      "./src/*.ts",
      "./src/*.tsx"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "node ../../scripts/rimraf.mjs dist .turbo"
  },
  "dependencies": {
    "@posthog/api-client": "workspace:*",
    "@posthog/core": "workspace:*",
    "@posthog/platform": "workspace:*",
    "@posthog/workspace-client": "workspace:*",
    "inversify": "catalog:",
    "reflect-metadata": "catalog:"
  },
  "peerDependencies": {
    "@phosphor-icons/react": "catalog:",
    "@posthog/quill": "catalog:",
    "@radix-ui/themes": "catalog:",
    "@tanstack/react-query": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@phosphor-icons/react": "catalog:",
    "@posthog/quill": "catalog:",
    "@posthog/tsconfig": "workspace:*",
    "@radix-ui/themes": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:"
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ]
}
