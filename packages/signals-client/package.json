{
  "name": "@posthog/signals-client",
  "version": "1.0.0",
  "description": "Portable facade over the PostHog signals/inbox/scouts/responders/tasks REST API. Pure HTTPS, runs in any JS environment. Constructed via factory function — no DI container.",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./*": [
      "./src/*.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "node ../../scripts/rimraf.mjs .turbo"
  },
  "devDependencies": {
    "@posthog/tsconfig": "workspace:*",
    "typescript": "catalog:",
    "vitest": "^2.1.9"
  },
  "files": [
    "src/**/*"
  ],
  "dependencies": {
    "@posthog/api-client": "workspace:*",
    "@posthog/shared": "workspace:*"
  }
}
