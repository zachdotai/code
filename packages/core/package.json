{
  "name": "@posthog/core",
  "version": "1.0.0",
  "description": "Zero-dependency pure domain layer. Types, schemas, pure functions. Runs in any JS environment (Node, Bun, browser, RN, edge). No I/O, no platform calls, no framework deps.",
  "private": true,
  "type": "module",
  "exports": {
    "./*": [
      "./src/*.ts",
      "./src/*.tsx"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "node ../../scripts/rimraf.mjs .turbo"
  },
  "dependencies": {
    "@posthog/shared": "workspace:*",
    "@posthog/workspace-client": "workspace:*"
  },
  "devDependencies": {
    "@posthog/tsconfig": "workspace:*",
    "typescript": "catalog:"
  },
  "files": [
    "src/**/*"
  ]
}
