{
  "name": "@posthog/workspace-server",
  "version": "1.0.0",
  "description": "Workspace server: hosts privileged local/sandbox work (git, fs, watchers, processes) behind a tRPC server",
  "private": true,
  "type": "module",
  "exports": {
    "./*": [
      "./src/*.ts",
      "./src/*.tsx"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "node ../../scripts/rimraf.mjs .turbo"
  },
  "dependencies": {
    "@hono/node-server": "catalog:",
    "@hono/trpc-server": "catalog:",
    "@parcel/watcher": "catalog:",
    "@posthog/git": "workspace:*",
    "@trpc/server": "catalog:",
    "hono": "catalog:",
    "ignore": "^7.0.5",
    "inversify": "catalog:",
    "reflect-metadata": "catalog:",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@posthog/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
